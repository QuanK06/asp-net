@{ ViewData["Title"] = "Donate - Ủng hộ"; }

<div class="breadcrumb-option">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="breadcrumb__links">
                    <a asp-controller="Home" asp-action="Index"><i class="fa fa-home"></i> Trang chủ</a>
                    <span>Donate</span>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="login spad">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="login__form text-center">
                    <i class="bi bi-heart-fill" style="font-size:3rem; color:#ff3d6e"></i>
                    <h3 class="mt-2 mb-3">Ủng hộ AnimeVietsub</h3>
                    <p class="text-muted">
                        Nếu bạn thấy web hữu ích, một lượt donate nhỏ sẽ giúp mình có thêm động lực
                        duy trì server, thêm anime mới và sửa lỗi nhanh hơn. Cảm ơn bạn rất nhiều! ❤️
                    </p>

                    <div class="row mt-4">
                        <div class="col-md-6 mb-4">
                            <div class="p-4" style="background:#1c1c22; border-radius:10px; height:100%">
                                <i class="bi bi-bank2" style="font-size:2rem; color:#ff3d6e"></i>
                                <h5 class="mt-2">Chuyển khoản ngân hàng</h5>
                                <p class="text-muted mb-1">(Đang cập nhật số tài khoản)</p>
                                <p class="text-muted small">Liên hệ trực tiếp qua Facebook/Email bên dưới để mình gửi thông tin chuyển khoản.</p>
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <div class="p-4" style="background:#1c1c22; border-radius:10px; height:100%">
                                <i class="bi bi-wallet2" style="font-size:2rem; color:#ff3d6e"></i>
                                <h5 class="mt-2">Ví điện tử (Momo/ZaloPay)</h5>
                                <p class="text-muted mb-1">(Đang cập nhật số ví)</p>
                                <p class="text-muted small">Liên hệ trực tiếp qua Facebook/Email bên dưới để mình gửi thông tin ví.</p>
                            </div>
                        </div>
                    </div>

                    <hr class="border-secondary my-4">

                    <h5 class="mb-3">Hoặc đơn giản là ủng hộ mình bằng cách theo dõi kênh 🎉</h5>
                    <a href="https://www.facebook.com/caohoaihoangquan" target="_blank" rel="noopener" class="btn btn-outline-light rounded-circle mr-2" style="width:50px; height:50px; display:inline-flex; align-items:center; justify-content:center">
                        <i class="bi bi-facebook"></i>
                    </a>
                    <a href="https://www.tiktok.com/quanfatigue" target="_blank" rel="noopener" class="btn btn-outline-light rounded-circle mr-2" style="width:50px; height:50px; display:inline-flex; align-items:center; justify-content:center">
                        <i class="bi bi-tiktok"></i>
                    </a>
                    <a href="mailto:chhq2006@gmail.com" class="btn btn-outline-light rounded-circle" style="width:50px; height:50px; display:inline-flex; align-items:center; justify-content:center">
                        <i class="bi bi-envelope-fill"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
