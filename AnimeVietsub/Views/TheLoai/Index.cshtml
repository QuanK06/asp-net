@model List<AnimeVietsub.Core.Models.TheLoai>
@{ ViewData["Title"] = "Thể loại"; }

<div class="breadcrumb-option">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="breadcrumb__links">
                    <a asp-controller="Home" asp-action="Index"><i class="fa fa-home"></i> Trang chủ</a>
                    <span>Thể loại</span>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="product-page spad">
    <div class="container">
        <div class="product__page__title">
            <div class="section-title"><h4>Tất cả thể loại</h4></div>
        </div>
        <div class="row">
            @foreach (var t in Model)
            {
                <div class="col-lg-6 col-md-8 col-sm-12">
                    <a asp-controller="Anime" asp-action="DanhSach" asp-route-theLoaiId="@t.TheLoaiId" class="product__sidebar__view__item set-bg d-block mb-4"
                       style="height:60px">
                        <h5 class="text-white">@t.TenTheLoai</h5>
                    </a>
                </div>
            }
        </div>
    </div>
</section>
