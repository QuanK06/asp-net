@{ ViewData["Title"] = "Đăng ký"; }

<section class="breadcrumb-option normal-breadcrumb set-bg" data-setbg="/template/img/normal-breadcrumb.jpg">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="normal__breadcrumb__text">
                    <h2>Đăng ký</h2>
                    <p>Tạo tài khoản để theo dõi và bình luận anime yêu thích.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="signup spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-6">
                <div class="login__form">
                    <h3>Đăng ký</h3>
                    <div asp-validation-summary="All" class="text-danger"></div>
                    <form method="post" asp-action="DangKy">
                        <div class="input__item">
                            <input type="email" name="email" placeholder="Email">
                            <span class="icon_mail"></span>
                        </div>
                        <div class="input__item">
                            <input type="text" name="hoTen" placeholder="Họ tên">
                            <span class="icon_profile"></span>
                        </div>
                        <div class="input__item">
                            <input type="password" name="matKhau" placeholder="Mật khẩu">
                            <span class="icon_lock"></span>
                        </div>
                        <button type="submit" class="site-btn">Đăng ký</button>
                    </form>
                    <h5>Đã có tài khoản? <a asp-action="DangNhap">Đăng nhập!</a></h5>
                </div>
            </div>
        </div>
    </div>
</section>
