@{ ViewData["Title"] = "Góp ý"; }

<div class="breadcrumb-option">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="breadcrumb__links">
                    <a asp-controller="Home" asp-action="Index"><i class="fa fa-home"></i> Trang chủ</a>
                    <span>Góp ý</span>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="login spad">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="login__form">
                    <h3 class="mb-2"><i class="bi bi-chat-square-heart"></i> Góp ý cho AnimeVietsub</h3>
                    <p class="text-muted">Bạn thấy web thiếu gì, lỗi gì, hay muốn đề xuất anime mới? Gửi cho mình nhé!</p>

                    <div id="thongBaoGui" class="alert alert-success d-none"></div>

                    <form id="formGopY">
                        <div class="input__item">
                            <input type="text" id="hoTen" placeholder="Họ tên (không bắt buộc)" value="@(User.Identity.IsAuthenticated ? User.Identity.Name : "")">
                            <span class="icon_profile"></span>
                        </div>
                        <div class="input__item">
                            <input type="email" id="email" placeholder="Email (không bắt buộc, để mình phản hồi)">
                            <span class="icon_mail"></span>
                        </div>
                        <div class="input__item">
                            <textarea id="noiDungGopY" placeholder="Nội dung góp ý..." style="width:100%; min-height:140px; padding:12px 20px; border:1px solid rgba(255,255,255,.2); background:transparent; color:#fff"></textarea>
                        </div>
                        <button type="button" id="btnGuiGopY" class="site-btn"><i class="bi bi-send"></i> Gửi góp ý</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
    $("#btnGuiGopY").click(function () {
        var noiDung = $("#noiDungGopY").val();
        if (!noiDung.trim()) { alert('Vui lòng nhập nội dung góp ý'); return; }

        $.post('/GopY/Gui', {
            hoTen: $("#hoTen").val(),
            email: $("#email").val(),
            noiDung: noiDung
        }, function (res) {
            if (res.success) {
                $("#thongBaoGui").removeClass('d-none').text('Cảm ơn bạn đã góp ý! Mình sẽ xem sớm nhất có thể 🎉');
                $("#formGopY")[0].reset();
            } else {
                alert(res.message);
            }
        });
    });
</script>
}
