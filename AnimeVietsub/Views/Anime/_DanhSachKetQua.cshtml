@model List<AnimeVietsub.Core.Models.Anime>
@{
    int tongSoTrang = ViewBag.TongSoTrang; int trangHienTai = ViewBag.TrangHienTai;
    int? theLoaiIdHienTai = ViewBag.TheLoaiIdHienTai;
    string tenTrang = ViewBag.TenTrang ?? "Danh sách Anime";
}
<div class="product__page__title">
    <div class="row">
        <div class="col-lg-8 col-md-8 col-sm-6">
            <div class="section-title"><h4>@tenTrang</h4></div>
        </div>
    </div>
</div>
<div class="row">
    @foreach (var a in Model)
    {
        <partial name="_AnimeCard" model="a" />
    }
    @if (!Model.Any()) { <p class="text-muted px-3">Chưa có anime nào.</p> }
</div>

@if (tongSoTrang > 1)
{
    <div class="product__pagination">
        @for (int i = 1; i <= tongSoTrang; i++)
        {
            <a href="#" class="lien-ket-trang @(i == trangHienTai ? "current-page" : "")" data-trang="@i">@i</a>
        }
    </div>
}
