@model List<AnimeVietsub.Core.Models.TinTuc>
@{ ViewData["Title"] = "Tin tức"; }

<div class="breadcrumb-option">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="breadcrumb__links">
                    <a asp-controller="Home" asp-action="Index"><i class="fa fa-home"></i> Trang chủ</a>
                    <span>Tin tức</span>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="blog spad">
    <div class="container">
        <div class="row">
            @foreach (var tt in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <a asp-action="ChiTiet" asp-route-id="@tt.TinTucId">
                        <div class="blog__item set-bg" data-setbg="@(string.IsNullOrEmpty(tt.AnhDaiDien) ? "/template/img/blog/blog-1.jpg" : tt.AnhDaiDien)" style="height:260px">
                            <div class="blog__item__text">
                                <p><span class="icon_calendar"></span> @tt.NgayDang.ToString("dd/MM/yyyy")</p>
                                <h4>@tt.TieuDe</h4>
                            </div>
                        </div>
                    </a>
                </div>
            }
            @if (!Model.Any()) { <p class="text-muted px-3">Chưa có tin tức nào.</p> }
        </div>
    </div>
</section>
