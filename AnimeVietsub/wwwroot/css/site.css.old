/* ==========================================================
   Lab 03: Giao dien nguoi dung - lay cam hung tu template
   "Vivid - Anime & Movies Streaming Entertainment Hub"
   Dark theme, hero banner lon, luoi poster anime
   ========================================================== */

:root {
    --bg-main: #0d0f14;
    --bg-card: #171a21;
    --bg-header: #11131a;
    --accent: #ff3d6e;
    --accent-2: #7b5cff;
    --text-main: #f2f2f5;
    --text-muted: #9a9ba3;
}

body {
    background-color: var(--bg-main);
    color: var(--text-main);
    font-family: "Segoe UI", Roboto, Arial, sans-serif;
}

a { text-decoration: none; }

/* ---------- Header ---------- */
.ash-header {
    background-color: var(--bg-header);
    border-bottom: 1px solid rgba(255,255,255,.06);
    position: sticky;
    top: 0;
    z-index: 999;
}

.ash-logo {
    font-weight: 800;
    font-size: 1.4rem;
    color: var(--text-main);
}
.ash-logo span { color: var(--accent); }

.ash-nav a {
    color: var(--text-muted);
    margin: 0 .75rem;
    font-weight: 500;
}
.ash-nav a:hover, .ash-nav a.active {
    color: var(--text-main);
}

.ash-search {
    background: #1e212b;
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 8px;
    color: var(--text-main);
}
.ash-search::placeholder { color: var(--text-muted); }

/* ---------- Hero banner ---------- */
.ash-hero {
    position: relative;
    min-height: 60vh;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: flex-end;
}
.ash-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--bg-main) 5%, rgba(13,15,20,.4) 60%, rgba(13,15,20,.1));
}
.ash-hero-content {
    position: relative;
    z-index: 2;
    padding: 2.5rem;
}
.ash-hero-title {
    font-size: 2.4rem;
    font-weight: 800;
}
.btn-ash-primary {
    background: linear-gradient(90deg, var(--accent), var(--accent-2));
    border: none;
    color: #fff;
    padding: .6rem 1.6rem;
    border-radius: 8px;
    font-weight: 600;
}
.btn-ash-primary:hover { opacity: .9; color: #fff; }

.btn-ash-outline {
    border: 1px solid rgba(255,255,255,.3);
    color: var(--text-main);
    padding: .6rem 1.6rem;
    border-radius: 8px;
    background: rgba(255,255,255,.05);
}

/* ---------- Section titles ---------- */
.ash-section-title {
    font-weight: 700;
    font-size: 1.3rem;
    border-left: 4px solid var(--accent);
    padding-left: .6rem;
    margin: 2rem 0 1rem;
}

/* ---------- Anime poster card ---------- */
.ash-card {
    background: var(--bg-card);
    border-radius: 10px;
    overflow: hidden;
    transition: transform .2s ease;
    position: relative;
}
.ash-card:hover {
    transform: translateY(-6px);
}
.ash-card img {
    width: 100%;
    aspect-ratio: 2/3;
    object-fit: cover;
}
.ash-card .ash-card-body {
    padding: .6rem .7rem;
}
.ash-card .ash-card-title {
    font-size: .92rem;
    font-weight: 600;
    color: var(--text-main);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.ash-badge-episode {
    position: absolute;
    top: 8px;
    right: 8px;
    background: var(--accent);
    color: #fff;
    font-size: .72rem;
    padding: 2px 8px;
    border-radius: 12px;
}

/* ---------- Footer ---------- */
.ash-footer {
    background: var(--bg-header);
    color: var(--text-muted);
    margin-top: 3rem;
    padding: 2rem 0;
    border-top: 1px solid rgba(255,255,255,.06);
}

/* ---------- Video player page ---------- */
.ash-player-wrap {
    background: #000;
    border-radius: 10px;
    overflow: hidden;
}
.ash-episode-btn {
    background: var(--bg-card);
    color: var(--text-muted);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 6px;
    padding: .4rem .3rem;
    text-align: center;
    display: block;
}
.ash-episode-btn.active, .ash-episode-btn:hover {
    background: var(--accent);
    color: #fff;
}
